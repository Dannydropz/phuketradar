# Database
DATABASE_URL=

# OpenAI API
OPENAI_API_KEY=

# Anthropic Claude (optional - switchable enrichment provider)
# Set ENRICHMENT_PROVIDER=anthropic to use Claude Sonnet for high-interest story enrichment
# Leave unset or set to 'openai' to use OpenAI GPT-4o (default)
ANTHROPIC_API_KEY=
ENRICHMENT_PROVIDER=openai
ANTHROPIC_MODEL=claude-sonnet-4-5

# Admin Password
ADMIN_PASSWORD=

# Session Secret
SESSION_SECRET=

# Facebook Page Access Token (for posting articles)
FB_PAGE_ACCESS_TOKEN=

# Cron API Key (for scheduled scraping via GitHub Actions)
CRON_API_KEY=

# Scraping Provider: 'scrapecreators' (single image) or 'apify' (multi-image support)
# Default: scrapecreators
SCRAPER_PROVIDER=apify

# ScrapeCreators API (single image scraping)
SCRAPECREATORS_API_KEY=

# Apify API (multi-image scraping)
APIFY_API_KEY=

# Meta Conversions API (for Facebook/Instagram ad tracking)
META_ACCESS_TOKEN=
META_PIXEL_ID=831369166474772
# Optional: Set this to a test event code for testing in Events Manager
META_TEST_EVENT_CODE=

# Beehiiv Newsletter
# Get your API key from: https://app.beehiiv.com/settings/integrations
# Get your Publication ID from: https://app.beehiiv.com/settings/publication (format: pub_xxxxx)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Resend (for transactional newsletter sending)
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@yourdomain.com
